---
interface Entry {
  dateRange: string;
  title: string;
  institution?: string;
  location?: string;
}

interface Props {
  term: string;
  entries: Entry[];
}

const { term, entries } = Astro.props;
---

<section class="term-group">
  <h2 class="term-heading">{term}</h2>
  <ul class="activity-list">
    {
      entries.map((entry) => (
        <li class="activity">
          <span class="activity-date">{entry.dateRange}</span>
          <span class="activity-desc">
            <span class="activity-title">{entry.title}</span>
            {entry.institution && (
              <span class="activity-institution">{entry.institution}</span>
            )}
            {entry.location && <span class="activity-location">{entry.location}</span>}
          </span>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .term-group {
    margin-bottom: 2.5rem;
  }

  .term-heading {
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    font-size: 1.15rem;
    border-bottom: 1px solid var(--color-border);
  }

  .activity-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .activity {
    display: grid;
    grid-template-columns: 12rem 1fr;
    gap: 0.15rem 1.25rem;
    padding: 0.7rem 0;
  }

  .activity + .activity {
    border-top: 1px solid var(--color-border);
  }

  .activity-date {
    font-size: 0.88rem;
    color: var(--color-muted);
    font-variant-numeric: tabular-nums;
    padding-top: 0.12rem;
  }

  .activity-desc {
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
  }

  /* Three-tier hierarchy: title > institution > location. */
  .activity-title {
    font-size: 1.02rem;
    font-weight: 600;
    color: var(--color-heading);
    line-height: 1.4;
  }

  .activity-institution {
    font-size: 0.9rem;
    color: var(--color-body);
  }

  .activity-location {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  @media (max-width: 34rem) {
    .activity {
      grid-template-columns: 1fr;
      gap: 0.2rem;
      padding: 0.8rem 0;
    }
  }
</style>
